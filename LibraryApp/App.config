<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <add name="MyConnectionString"
         connectionString="Data Source=.;Initial Catalog=LibraryDB;Integrated Security=True;Connect Timeout=30;Encrypt=True;TrustServerCertificate=True;ApplicationIntent=ReadWrite;MultiSubnetFailover=False"

         providerName="System.Data.SqlClient" />
  </connectionStrings>
</configuration>